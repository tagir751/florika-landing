// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String
  role      Role     @default(SELLER)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  bookings  Booking[]
}

enum Role {
  SELLER
  MANAGER
  OWNER
}

model Excursion {
  id          String   @id @default(cuid())
  name        String
  description String
  price       Float
  duration    String?
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  bookings    Booking[]
}

model Pickup {
  id        String   @id @default(cuid())
  name      String
  address   String?
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  bookings  Booking[]
}

model Driver {
  id        String   @id @default(cuid())
  name      String
  phone     String
  capacity  Int?
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  bookings  Booking[]
}

model Guide {
  id        String   @id @default(cuid())
  name      String
  phone     String
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  bookings  Booking[]
}

model Point {
  id        String   @id @default(cuid())
  name      String
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  bookings  Booking[]
}

model Agent {
  id        String   @id @default(cuid())
  name      String
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  bookings  Booking[]
}

model Booking {
  id              String   @id @default(cuid())
  excursionId     String
  pickupId        String
  driverId        String?
  guideId         String?
  pointId         String?
  agentId         String?
  userId          String
  customerName    String
  customerPhone   String
  seats           Int      @default(1)
  totalPrice      Float
  status          String   @default("PENDING")
  tripDate        DateTime
  notes           String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  
  excursion       Excursion @relation(fields: [excursionId], references: [id])
  pickup          Pickup    @relation(fields: [pickupId], references: [id])
  driver          Driver?   @relation(fields: [driverId], references: [id])
  guide           Guide?    @relation(fields: [guideId], references: [id])
  point           Point?    @relation(fields: [pointId], references: [id])
  agent           Agent?    @relation(fields: [agentId], references: [id])
  user            User      @relation(fields: [userId], references: [id])
}

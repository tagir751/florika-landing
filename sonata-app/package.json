{
  "name": "sonata-app",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "npx next dev --turbo",
    "build": "TOKIO_WORKER_THREADS=1 TASK_CONCURRENCY=1 NODE_OPTIONS='--max-old-space-size=400' npx next build",
    "start": "node .next/standalone/server.js",
    "lint": "next lint",
    "db:migrate": "prisma migrate dev",
    "db:push": "prisma db push",
    "db:seed": "ts-node --compiler-options \"{\\\"module\\\":\\\"CommonJS\\\"}\" prisma/seed.ts",
    "prisma:gen": "npx prisma generate",
    "copy-static": "rm -rf _next && mkdir -p _next && cp -r .next/static _next/ && cp -r .next/standalone/.next _next/",
    "deploy:build": "npm run build && npm run copy-static",
    "restart": "touch tmp/restart.txt",
    "logs": "tail -f debug.log",
    "check": "ls -la .next/standalone/server.js && ls -la _next/static/"
  },
  "dependencies": {
    "next": "14.2.5",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "@prisma/client": "^5.17.0",
    "bcryptjs": "^2.4.3",
    "next-auth": "^4.24.7"
  },
  "devDependencies": {
    "@types/node": "^20.14.11",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@types/bcryptjs": "^2.4.6",
    "typescript": "^5.5.3",
    "prisma": "^5.17.0",
    "ts-node": "^10.9.2",
    "tailwindcss": "^3.4.6",
    "postcss": "^8.4.39",
    "autoprefixer": "^10.4.19"
  }
}
